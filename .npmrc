# npm configuration for security and optimization
# Shai-Hulud 2.0 countermeasures included

# Enable audit on install to detect vulnerabilities
audit=true

# Disable funding messages
fund=false

# Ensure package-lock.json is always created
package-lock=true

# Use npm registry (explicit for security)
registry=https://registry.npmjs.org/

# Note: optional dependencies are allowed for build tools (e.g., rollup native modules)
# Security is maintained through save-exact=true and ignore-scripts=true
# optional=false

# Save exact versions to prevent unexpected updates
save-exact=true

# Prevent scripts from running during install (security measure against malicious scripts)
# Note: This prevents preinstall/postinstall scripts which could be used by malware
ignore-scripts=true
